# Neon PostgreSQL (verplicht)
# Gebruik de POOLED connection string (-pooler in hostname) voor snellere serverless queries
# Neon dashboard → Connection details → "Pooled connection"
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Auth.js (verplicht in productie)
# Genereer: openssl rand -base64 32
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Canonical app-URL (zonder trailing slash).
# Lokaal:
AUTH_URL=http://localhost:3000
# Vercel vóór custom domain (pas aan naar jouw *.vercel.app URL):
# AUTH_URL=https://erp-gamma-peach.vercel.app
# Na custom domain:
# AUTH_URL=https://app.champagneisart.nl
#
# Als AUTH_URL ontbreekt op Vercel, valt de app terug op VERCEL_URL (automatisch gezet).
# trustHost staat aan in code; AUTH_TRUST_HOST=true is optioneel extra op Vercel.
AUTH_TRUST_HOST=true

# Hosts — pas aan wanneer custom subdomains live zijn (niet nodig op *.vercel.app)
NEXT_PUBLIC_APP_HOST=app.champagneisart.nl
NEXT_PUBLIC_ARTIST_HOST=artist.champagneisart.nl
NEXT_PUBLIC_STATUS_HOST=status.champagneisart.nl

# Vercel Blob (optional in dev)
BLOB_READ_WRITE_TOKEN=

# OpenAI (inbox AI, optional)
OPENAI_API_KEY=
# Optioneel — overschrijft Instellingen → chatmodel
# OPENAI_MODEL=gpt-4o-mini
# Optioneel — voor toekomstige kennisbank-RAG (nog niet actief in code)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cron healthcheck (production)
CRON_SECRET=generate-random-string

# WordPress / Avada formulieren (website → ERP)
WEBHOOK_SECRET=generate-random-string-min-32-chars

# Mailjet (optioneel — voor wachtwoord-vergeten mails)
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
MAILJET_FROM_EMAIL=noreply@champagneisart.nl
MAILJET_FROM_NAME=Champagne is Art Studio
