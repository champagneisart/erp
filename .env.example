# Neon PostgreSQL (verplicht)
# Neon dashboard → Connection details → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Auth.js
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Hosts (production subdomains)
NEXT_PUBLIC_APP_HOST=app.champagneisart.nl
NEXT_PUBLIC_ARTIST_HOST=artist.champagneisart.nl
NEXT_PUBLIC_STATUS_HOST=status.champagneisart.nl

# Vercel Blob (optional in dev)
BLOB_READ_WRITE_TOKEN=

# OpenAI (inbox AI, optional)
OPENAI_API_KEY=

# Cron healthcheck (production)
CRON_SECRET=generate-random-string
